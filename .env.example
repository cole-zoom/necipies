# --- Supabase (client-side; safe to ship the publishable/anon key) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Gemini (SERVER-SIDE ONLY; used by /api/extract-recipe) ---
# Do NOT prefix with VITE_ — that would expose it to the browser.
GEMINI_API_KEY=

# --- Google Analytics (client-side) ---
VITE_GA_MEASUREMENT_ID=

# --- Microsoft Clarity (optional, client-side) ---
VITE_CLARITY_PROJECT_ID=

# --- App display ---
VITE_APP_NAME=Necepies
